# PredictFun public example env
# Fill these values with your own credentials locally.
# Do not commit real values.

# Human-friendly names
PREDICTFUN_API_KEY=YOUR_API_KEY_HERE
PREDICTFUN_WALLET_ADDRESS=YOUR_WALLET_OR_PREDICT_ACCOUNT_ADDRESS_HERE
PREDICTFUN_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE

